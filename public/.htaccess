Options -MultiViews

# JavaScript modülleri için doğru MIME type (pdf.worker .mjs için kritik)
<IfModule mod_mime.c>
  AddType application/javascript .mjs
  AddType application/javascript .js
  AddType application/wasm .wasm
</IfModule>

# Bazı hostlar mod_mime'ı override ediyor — header ile zorla
<IfModule mod_headers.c>
  <FilesMatch "\.mjs$">
    Header set Content-Type "application/javascript"
  </FilesMatch>

  # SEO audit: HSTS — tüm cevaplara HTTPS-zorlama bildirimi
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # SEO audit (2026-05-27): Security headers — Screaming Frog audit'i kapatır
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"

  # CSP — ÖNCE Report-Only modda (site kırılmasın). 1-2 hafta gözlem sonrası
  # browser console'da hata yoksa "Content-Security-Policy" olarak değiştirilecek.
  # React/Vite inline JSON-LD ve style attribute kullanır → unsafe-inline gerekli.
  Header always set Content-Security-Policy-Report-Only "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://www.youtube.com https://player.vimeo.com https://*.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:; connect-src 'self' https: wss:; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com https://www.googletagmanager.com; worker-src 'self' blob:; child-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https:; frame-ancestors 'self';"

  # SEO audit: PDF/image gibi statik asset'ler arama sonuçlarında listelenmesin
  <FilesMatch "\.(pdf|png|jpg|jpeg|svg|webp|gif|ico|css|js|mjs|woff|woff2|ttf|eot)$">
    Header set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>

  # ÖNEMLİ: Favicon noindex'ten MUAF olmalı — aksi halde Google arama sonucunda
  # site favicon'unu GÖSTERMEZ (yukarıdaki png/ico kuralı favicon'u da kapsıyordu).
  # Bu blok sonra geldiği için X-Robots-Tag'i favicon için "all" (kısıt yok) ile geçersiz kılar.
  <FilesMatch "^(favicon-300x300\.png|favicon\.png|favicon\.ico|apple-touch-icon\.png)$">
    Header set X-Robots-Tag "all"
  </FilesMatch>
</IfModule>

# Apache mod_dir'in otomatik trailing slash eklemesini kapat (canonical = no-slash)
DirectorySlash Off

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # /api/ isteklerini PHP backend'e bırak
  RewriteRule ^api/ - [L]

  # ÖNCE: Eski sitemap URL'lerini Yoast tarzı yeni isimlere 301 redirect
  # (Sıra önemli: direct-serve pattern eski isimleri match etmesin diye redirect'ler önce)
  RewriteRule ^sitemap\.xml$ /sitemap_index.xml [R=301,L]
  RewriteRule ^sitemap-pages\.xml$ /page-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-services\.xml$ /service-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-sectoral\.xml$ /sectoral-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-products\.xml$ /product-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-trainings\.xml$ /training-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-flows\.xml$ /flow-sitemap.xml [R=301,L]

  # SONRA: Crawl ve makine-okunur statik dosyaları dogrudan servis et (sadece YENİ isimler)
  RewriteRule ^(robots\.txt|sitemap_index\.xml|sitemap\.xsl|[a-z]+-sitemap\.xml|llms\.txt|llm\.txt)$ - [L]

  # Trailing slash'i kanonikalleştir: /foo/ → /foo (ana sayfa hariç)
  # SEO: hreflang ve canonical URL'leri trailing slash'siz, Apache de aynı şekilde serve etsin
  RewriteCond %{REQUEST_URI} ^.+/$
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # /foo (slash yok, ama prerender klasörü var) → internal olarak /foo/index.html serve et
  # Böylece URL slash'siz kalır, crawler 200 alır.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ /$1/index.html [L]

  # SEO audit fix: asset extension'lı (.png, .jpg, .css, .js, .pdf vb.) URL'lere
  # dosya yoksa SPA index.html dönmek yerine 404 dön. Aksi takdirde crawler
  # PNG isteğine HTML cevap alıp canonical "/" görüyor (yanlış canonical bug).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule \.(png|jpg|jpeg|webp|avif|gif|svg|ico|css|js|mjs|map|pdf|zip|woff|woff2|ttf|eot|mp4|webm|mp3|wav|xml|txt|json)$ - [R=404,L]

  # Gerçek dosya varsa dokunma (assets, images vb.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Geri kalanı SPA index.html'e yönlendir
  RewriteRule . /index.html [L]
</IfModule>
