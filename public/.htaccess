Options -MultiViews

# JavaScript modülleri için doğru MIME type (pdf.worker .mjs için kritik)
<IfModule mod_mime.c>
  AddType application/javascript .mjs
  AddType application/javascript .js
  AddType application/wasm .wasm
</IfModule>

# Bazı hostlar mod_mime'ı override ediyor — header ile zorla
<IfModule mod_headers.c>
  <FilesMatch "\.mjs$">
    Header set Content-Type "application/javascript"
  </FilesMatch>
</IfModule>

# Apache mod_dir'in otomatik trailing slash eklemesini kapat (canonical = no-slash)
DirectorySlash Off

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # /api/ isteklerini PHP backend'e bırak
  RewriteRule ^api/ - [L]

  # Crawl ve makine-okunur statik dosyalari her zaman dogrudan servis et
  RewriteRule ^(robots\.txt|sitemap\.xml|sitemap-[^.]+\.xml|llms\.txt|llm\.txt)$ - [L]

  # Trailing slash'i kanonikalleştir: /foo/ → /foo (ana sayfa hariç)
  # SEO: hreflang ve canonical URL'leri trailing slash'siz, Apache de aynı şekilde serve etsin
  RewriteCond %{REQUEST_URI} ^.+/$
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # /foo (slash yok, ama prerender klasörü var) → internal olarak /foo/index.html serve et
  # Böylece URL slash'siz kalır, crawler 200 alır.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ /$1/index.html [L]

  # Gerçek dosya varsa dokunma (assets, images vb.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Geri kalanı SPA index.html'e yönlendir
  RewriteRule . /index.html [L]
</IfModule>
