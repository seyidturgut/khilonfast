Options -MultiViews

# JavaScript modĂĽlleri iĂ§in doÄźru MIME type (pdf.worker .mjs iĂ§in kritik)
<IfModule mod_mime.c>
  AddType application/javascript .mjs
  AddType application/javascript .js
  AddType application/wasm .wasm
</IfModule>

# BazÄ± hostlar mod_mime'Ä± override ediyor â€” header ile zorla
<IfModule mod_headers.c>
  <FilesMatch "\.mjs$">
    Header set Content-Type "application/javascript"
  </FilesMatch>

  # SEO audit: HSTS â€” tĂĽm cevaplara HTTPS-zorlama bildirimi
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # SEO audit: PDF/image gibi statik asset'ler arama sonuĂ§larÄ±nda listelenmesin
  <FilesMatch "\.(pdf|png|jpg|jpeg|svg|webp|gif|ico|css|js|mjs|woff|woff2|ttf|eot)$">
    Header set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>
</IfModule>

# Apache mod_dir'in otomatik trailing slash eklemesini kapat (canonical = no-slash)
DirectorySlash Off

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # /api/ isteklerini PHP backend'e bÄ±rak
  RewriteRule ^api/ - [L]

  # Ă–NCE: Eski sitemap URL'lerini Yoast tarzÄ± yeni isimlere 301 redirect
  # (SÄ±ra Ă¶nemli: direct-serve pattern eski isimleri match etmesin diye redirect'ler Ă¶nce)
  RewriteRule ^sitemap\.xml$ /sitemap_index.xml [R=301,L]
  RewriteRule ^sitemap-pages\.xml$ /page-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-services\.xml$ /service-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-sectoral\.xml$ /sectoral-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-products\.xml$ /product-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-trainings\.xml$ /training-sitemap.xml [R=301,L]
  RewriteRule ^sitemap-flows\.xml$ /flow-sitemap.xml [R=301,L]

  # SONRA: Crawl ve makine-okunur statik dosyalarÄ± dogrudan servis et (sadece YENÄ° isimler)
  RewriteRule ^(robots\.txt|sitemap_index\.xml|sitemap\.xsl|[a-z]+-sitemap\.xml|llms\.txt|llm\.txt)$ - [L]

  # Trailing slash'i kanonikalleĹźtir: /foo/ â†’ /foo (ana sayfa hariĂ§)
  # SEO: hreflang ve canonical URL'leri trailing slash'siz, Apache de aynÄ± Ĺźekilde serve etsin
  RewriteCond %{REQUEST_URI} ^.+/$
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # /foo (slash yok, ama prerender klasĂ¶rĂĽ var) â†’ internal olarak /foo/index.html serve et
  # BĂ¶ylece URL slash'siz kalÄ±r, crawler 200 alÄ±r.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ /$1/index.html [L]

  # GerĂ§ek dosya varsa dokunma (assets, images vb.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Geri kalanÄ± SPA index.html'e yĂ¶nlendir
  RewriteRule . /index.html [L]
</IfModule>
