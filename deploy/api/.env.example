# Production Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password
DB_NAME=your_cpanel_db_name

# Server
PORT=3002
NODE_ENV=production
JWT_SECRET=generate-a-random-secret-key

# Lidio (Optional)
LIDIO_API_KEY=
LIDIO_SECRET_KEY=
LIDIO_MERCHANT_ID=
LIDIO_API_URL=https://api.lidio.com
LIDIO_TEST_MODE=true

# Frontend URL
FRONTEND_URL=https://khilonfast.com
